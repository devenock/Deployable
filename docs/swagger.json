{
    "schemes": [
        "http",
        "https"
    ],
    "swagger": "2.0",
    "info": {
        "description": "Deployment Readiness Platform — Phase 1 (Foundation) API surface. Endpoints marked 501 are intentional stubs; full implementations land in later phases (see the description on each operation for which phase).",
        "title": "Deployable API",
        "contact": {
            "name": "Deployable"
        },
        "version": "0.1.0-phase1"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/": {
            "get": {
                "description": "Public marketing landing page.",
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "web"
                ],
                "summary": "Landing page",
                "responses": {
                    "200": {
                        "description": "HTML page",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/analyze": {
            "get": {
                "description": "Requires a valid session_id cookie (checked against Redis first, Postgres on cache miss). Full zip/GitHub/CLI input handling and the processing pipeline land in Phase 2 — this stub proves auth and routing work end to end.",
                "tags": [
                    "web"
                ],
                "summary": "Analyze page (stub)",
                "responses": {
                    "303": {
                        "description": "No valid session — redirects to /login",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "501": {
                        "description": "not implemented",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/analyze": {
            "post": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Requires an X-API-Key header. The key is SHA-256 hashed and checked against Redis first, then Postgres (users.api_key_hash) on a cache miss. Subject to Redis-backed rate limiting (default 5/hour, keyed on the X-Real-IP header set by Caddy). Full submission handling lands in Phase 4.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "api"
                ],
                "summary": "Submit an analysis (stub)",
                "responses": {
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "429": {
                        "description": "Too Many Requests",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "501": {
                        "description": "not implemented",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/api/v1/analyze/{jobID}": {
            "get": {
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ],
                "description": "Requires an X-API-Key header. Job status polling lands in Phase 4.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "api"
                ],
                "summary": "Get analysis job status (stub)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Analysis job ID",
                        "name": "jobID",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "401": {
                        "description": "Unauthorized",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "429": {
                        "description": "Too Many Requests",
                        "schema": {
                            "$ref": "#/definitions/handlers.ErrorResponse"
                        }
                    },
                    "501": {
                        "description": "not implemented",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/dashboard": {
            "get": {
                "description": "Requires a valid session_id cookie. Saved reports list lands in Phase 5.",
                "tags": [
                    "web"
                ],
                "summary": "Dashboard (stub)",
                "responses": {
                    "303": {
                        "description": "No valid session — redirects to /login",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "501": {
                        "description": "not implemented",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Pings Postgres and Redis and reports overall status. Used by Docker healthchecks and uptime monitoring.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "system"
                ],
                "summary": "Health check",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/handlers.HealthResponse"
                        }
                    },
                    "503": {
                        "description": "Service Unavailable",
                        "schema": {
                            "$ref": "#/definitions/handlers.HealthResponse"
                        }
                    }
                }
            }
        },
        "/login": {
            "get": {
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Login form",
                "responses": {
                    "200": {
                        "description": "HTML form",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Validates credentials against the stored bcrypt hash. On success creates a session and sets the session_id cookie. On failure (unknown email or wrong password) re-renders the login form with a generic \"Invalid email or password\" error — no session is created and which field was wrong is never disclosed.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Sign in",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Email address",
                        "name": "email",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Password",
                        "name": "password",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Invalid credentials — form re-rendered with error, no session created",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "303": {
                        "description": "Redirects to /analyze; Set-Cookie: session_id=...",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/logout": {
            "post": {
                "description": "Deletes the session from Postgres and Redis, clears the session_id cookie (Max-Age=0), and redirects to /login. Requires a session_id cookie.",
                "tags": [
                    "auth"
                ],
                "summary": "Sign out",
                "responses": {
                    "303": {
                        "description": "Redirects to /login; cookie cleared",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/register": {
            "get": {
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Registration form",
                "responses": {
                    "200": {
                        "description": "HTML form",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "description": "Validates name/email/password (min 8 chars), bcrypt-hashes the password (cost 12), creates the user and an initial session, and sets the session_id cookie (HttpOnly, SameSite=Lax, 30-day expiry). Duplicate emails and validation failures re-render the form with 200 and an inline error instead of an HTTP error status.",
                "consumes": [
                    "application/x-www-form-urlencoded"
                ],
                "produces": [
                    "text/html"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Create an account",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Full name",
                        "name": "name",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Email address",
                        "name": "email",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Password, minimum 8 characters",
                        "name": "password",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Validation failed or email already registered — form re-rendered with error",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "303": {
                        "description": "Redirects to /analyze; Set-Cookie: session_id=...",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "handlers.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string",
                    "example": "invalid or missing API key"
                }
            }
        },
        "handlers.HealthResponse": {
            "type": "object",
            "properties": {
                "postgres": {
                    "type": "string",
                    "example": "ok"
                },
                "redis": {
                    "type": "string",
                    "example": "ok"
                },
                "status": {
                    "type": "string",
                    "example": "ok"
                },
                "version": {
                    "type": "string",
                    "example": "dev"
                }
            }
        }
    },
    "securityDefinitions": {
        "ApiKeyAuth": {
            "description": "Per-user API key (Phase 4 issues these). SHA-256 hash is checked against users.api_key_hash. Session-cookie-protected web routes (/analyze, /dashboard, /logout) are documented per-operation since Swagger 2.0 has no cookie security scheme.",
            "type": "apiKey",
            "name": "X-API-Key",
            "in": "header"
        }
    }
}